# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
PCGCitySampleStudy/SourceArt/**/*.png
PCGCitySampleStudy/SourceArt/**/*.tga

# Binary Files
PCGCitySampleStudy/Binaries/*
PCGCitySampleStudy/Plugins/**/Binaries/*

# Builds


# Whitelist PakBlacklist-<BuildConfiguration>.txt files

!PCGCitySampleStudy/Build/*/
PCGCitySampleStudy/Build/*/**
!PCGCitySampleStudy/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

