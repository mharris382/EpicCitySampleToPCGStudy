# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
CitySampleStudy/SourceArt/**/*.png
CitySampleStudy/SourceArt/**/*.tga

# Binary Files
CitySampleStudy/Binaries/*
CitySampleStudy/Plugins/**/Binaries/*

# Builds
CitySampleStudy/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!CitySampleStudy/Build/*/
CitySampleStudy/Build/*/**
!CitySampleStudy/Build/*/PakBlacklist*.txt
!ArchitectCore_5_7/Build/*/
ArchitectCore_5_7/Build/*/**
!ArchitectCore_5_7/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
CitySampleStudy/Saved/*
ArchitectCore_5_7/Saved/*

# Compiled source files for the engine to use
CitySampleStudy/Intermediate/*
CitySampleStudy/Plugins/**/Intermediate/*
ArchitectCore_5_7/Intermediate/*
